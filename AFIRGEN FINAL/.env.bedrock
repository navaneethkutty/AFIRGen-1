# AFIRGen Bedrock Migration Environment Configuration
# This file contains AWS service configurations for the Bedrock migration
# Copy this file to .env when deploying with Bedrock architecture

# ============================================================================
# Feature Flag
# ============================================================================
# Set to 'true' to use Bedrock services, 'false' to use GGUF models
ENABLE_BEDROCK=true

# ============================================================================
# AWS Configuration
# ============================================================================
# AWS region for all services (Bedrock, Transcribe, Textract, S3, etc.)
AWS_REGION=us-east-1

# S3 bucket name for temporary file storage (audio, images)
S3_BUCKET_NAME=afirgen-bedrock-temp-files

# ============================================================================
# Amazon Bedrock Configuration
# ============================================================================
# Bedrock model ID for legal text processing (Claude 3 Sonnet)
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Bedrock embeddings model ID for vector generation (Titan Embeddings)
BEDROCK_EMBEDDINGS_MODEL_ID=amazon.titan-embed-text-v1

# Maximum concurrent Bedrock API calls (default: 10)
BEDROCK_MAX_CONCURRENT_CALLS=10

# Bedrock API timeout in seconds (default: 60)
BEDROCK_TIMEOUT=60

# ============================================================================
# Amazon Transcribe Configuration
# ============================================================================
# Supported language codes (comma-separated)
# Supported: hi-IN, en-IN, ta-IN, te-IN, bn-IN, mr-IN, gu-IN, kn-IN, ml-IN, pa-IN
TRANSCRIBE_LANGUAGES=hi-IN,en-IN,ta-IN,te-IN,bn-IN,mr-IN,gu-IN,kn-IN,ml-IN,pa-IN

# Default language code when auto-detection fails
TRANSCRIBE_DEFAULT_LANGUAGE=hi-IN

# Transcribe job timeout in seconds (default: 300 = 5 minutes)
TRANSCRIBE_TIMEOUT=300

# ============================================================================
# Amazon Textract Configuration
# ============================================================================
# Textract API timeout in seconds (default: 60)
TEXTRACT_TIMEOUT=60

# Enable form data extraction (true/false)
TEXTRACT_EXTRACT_FORMS=true

# ============================================================================
# Vector Database Configuration
# ============================================================================
# Vector database type: "opensearch" or "aurora_pgvector"
VECTOR_DB_TYPE=opensearch

# Vector database index/table name for IPC sections
VECTOR_DB_INDEX_NAME=ipc_sections

# Embedding dimension (Titan Embeddings generates 1536-dimensional vectors)
VECTOR_DB_EMBEDDING_DIMENSION=1536

# Number of top results to return from similarity search (default: 5)
VECTOR_DB_TOP_K=5

# ============================================================================
# OpenSearch Serverless Configuration (if VECTOR_DB_TYPE=opensearch)
# ============================================================================
# OpenSearch Serverless endpoint URL
# Replace with your actual OpenSearch Serverless collection endpoint
OPENSEARCH_ENDPOINT=https://change-to-your-collection-id.us-east-1.aoss.amazonaws.com

# OpenSearch index settings
OPENSEARCH_INDEX_NAME=ipc_sections

# OpenSearch connection timeout in seconds
OPENSEARCH_TIMEOUT=30

# ============================================================================
# Aurora PostgreSQL with pgvector Configuration (if VECTOR_DB_TYPE=aurora_pgvector)
# ============================================================================
# Aurora PostgreSQL host
AURORA_HOST=your-aurora-cluster.cluster-xxxxx.us-east-1.rds.amazonaws.com

# Aurora PostgreSQL port (default: 5432)
AURORA_PORT=5432

# Aurora PostgreSQL database name
AURORA_DATABASE=afirgen_vectors

# Aurora PostgreSQL username
AURORA_USER=postgres

# Aurora PostgreSQL password (use AWS Secrets Manager in production)
AURORA_PASSWORD=your-secure-password

# Aurora table name for IPC sections
AURORA_TABLE_NAME=ipc_sections

# Aurora connection pool size (default: 10)
AURORA_POOL_SIZE=10

# Aurora connection timeout in seconds
AURORA_TIMEOUT=30

# Enable SSL for Aurora connection (true/false)
AURORA_SSL=true

# ============================================================================
# Retry and Resilience Configuration
# ============================================================================
# Maximum number of retries for AWS service calls (default: 2)
MAX_RETRIES=2

# Base delay for exponential backoff in seconds (default: 1.0)
RETRY_BASE_DELAY=1.0

# Maximum delay for exponential backoff in seconds (default: 60.0)
RETRY_MAX_DELAY=60.0

# Circuit breaker failure threshold (default: 5)
CIRCUIT_BREAKER_FAILURE_THRESHOLD=5

# Circuit breaker recovery timeout in seconds (default: 60)
CIRCUIT_BREAKER_RECOVERY_TIMEOUT=60

# Circuit breaker half-open max calls (default: 3)
CIRCUIT_BREAKER_HALF_OPEN_MAX_CALLS=3

# ============================================================================
# Caching Configuration
# ============================================================================
# IPC section cache size (number of queries to cache)
IPC_CACHE_SIZE=100

# Cache TTL in seconds (default: 3600 = 1 hour)
CACHE_TTL=3600

# ============================================================================
# Monitoring and Observability Configuration
# ============================================================================
# CloudWatch metrics namespace
CLOUDWATCH_NAMESPACE=AFIRGen/Bedrock

# Enable X-Ray tracing (true/false)
ENABLE_XRAY_TRACING=true

# Enable structured JSON logging (true/false)
ENABLE_STRUCTURED_LOGGING=true

# Log level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# Security Configuration
# ============================================================================
# KMS key ID for S3 encryption (leave empty to use default AWS managed key)
KMS_KEY_ID=

# Enable VPC endpoints for AWS services (true/false)
USE_VPC_ENDPOINTS=true

# ============================================================================
# Performance Configuration
# ============================================================================
# Maximum file size for audio uploads in MB (default: 100)
MAX_AUDIO_FILE_SIZE_MB=100

# Maximum file size for image uploads in MB (default: 10)
MAX_IMAGE_FILE_SIZE_MB=10

# S3 lifecycle policy - delete files older than N days (default: 7)
S3_LIFECYCLE_DAYS=7

# ============================================================================
# MySQL Database Configuration (unchanged from existing setup)
# ============================================================================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=password
MYSQL_DB=fir_db

# ============================================================================
# Application Configuration (unchanged from existing setup)
# ============================================================================
PORT=8000
FIR_AUTH_KEY=your-secure-auth-key-here-change-in-production
API_KEY=change-this-to-secure-32-char-key-in-production

# ============================================================================
# CORS Configuration (unchanged from existing setup)
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ============================================================================
# Rate Limiting Configuration (unchanged from existing setup)
# ============================================================================
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ============================================================================
# Security Configuration (unchanged from existing setup)
# ============================================================================
ENFORCE_HTTPS=false
SESSION_TIMEOUT=3600

# ============================================================================
# Frontend Configuration (unchanged from existing setup)
# ============================================================================
API_BASE_URL=http://localhost:8000
ENVIRONMENT=development
ENABLE_DEBUG=true
FRONTEND_PORT=80

# ============================================================================
# Backup Configuration (unchanged from existing setup)
# ============================================================================
BACKUP_RETENTION_DAYS=7

# ============================================================================
# AWS Secrets Manager Configuration (unchanged from existing setup)
# ============================================================================
USE_AWS_SECRETS=false
