# AFIRGen Backend - AWS Bedrock Architecture
# Copy this file to .env and fill in your values

# ============================================================================
# REQUIRED CONFIGURATION
# ============================================================================

# AWS Configuration
AWS_REGION=us-east-1

# S3 Bucket for temporary file storage
S3_BUCKET_NAME=your-bucket-name

# MySQL RDS Configuration
DB_HOST=afirgen-free-tier-mysql.ceniwmoioy4y.us-east-1.rds.amazonaws.com
DB_PORT=3306
DB_USER=admin
DB_PASSWORD=your-secure-password
DB_NAME=afirgen_db

# API Authentication
API_KEY=your-secure-api-key-min-32-chars

# ============================================================================
# OPTIONAL CONFIGURATION (with defaults)
# ============================================================================

# Bedrock Model Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100

# File Upload Limits
MAX_FILE_SIZE_MB=10

# Timeouts (in seconds)
TRANSCRIBE_TIMEOUT_SECONDS=180
BEDROCK_TIMEOUT_SECONDS=60

# Retry Configuration
MAX_RETRIES=2
RETRY_DELAY_SECONDS=2

# ============================================================================
# AWS CREDENTIALS (for local development)
# ============================================================================
# For EC2 deployment, use IAM role instead of credentials
# AWS_ACCESS_KEY_ID=your-access-key
# AWS_SECRET_ACCESS_KEY=your-secret-key

# ============================================================================
# NOTES
# ============================================================================
# - For EC2 deployment, configure IAM role with permissions for:
#   - Bedrock (invoke model)
#   - Transcribe (start/get transcription jobs)
#   - Textract (detect document text)
#   - S3 (read/write/delete objects)
#   - RDS MySQL (network access via security groups)
# - Ensure RDS security group allows EC2 instance access
# - Ensure S3 bucket has appropriate permissions
